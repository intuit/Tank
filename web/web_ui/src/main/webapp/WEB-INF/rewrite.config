# SPA fallback: any /app/* request that isn't a static asset gets rewritten to /app/index.html
RewriteCond %{REQUEST_URI} ^/[^/]+/app/
RewriteCond %{REQUEST_URI} !^/[^/]+/app/assets/
RewriteCond %{REQUEST_URI} !^/[^/]+/app/index\.html
RewriteCond %{REQUEST_URI} !\.(js|css|png|ico|svg|woff2?)$
RewriteRule ^/([^/]+)/app/(.*)$ /$1/app/index.html [L]
